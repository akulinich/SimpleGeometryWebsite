---
// Full-bleed editor page: deliberately NOT BaseLayout (no max-width chrome).
// The React SPA owns the whole viewport and is client-only (no SSR).
import SandboxApp from '../sandbox/SandboxApp.tsx';
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Песочница — Simple Geometry</title>
    <link rel="icon" type="image/png" href={`${base}/tor.png`} />
  </head>
  <body>
    <SandboxApp client:only="react" />
  </body>
</html>
