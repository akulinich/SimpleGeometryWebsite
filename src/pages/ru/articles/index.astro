---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticlesIndex from '../../../components/ArticlesIndex.astro';
import { useTranslations } from '../../../i18n/ui';

const lang = 'ru';
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={t('articles.heading')} lang={lang} otherLangUrl={`${base}/en/articles/`}>
  <ArticlesIndex lang={lang} />
</BaseLayout>
